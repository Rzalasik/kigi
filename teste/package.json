    "cy:runComercial": "npx cypress run --browser chrome --spec cypress/e2e/Testes-Comercial.cy.js",
    "cy:runFiscal": "QASE_MODE=testops npx cypress run --browser chrome --spec cypress/e2e/Testes-Fiscal.cy.js",
    "cy:runLogin": "npx cypress run --browser chrome --spec cypress/e2e/Testes-Login.cy.js",
